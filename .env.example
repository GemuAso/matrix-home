# =============================================================================
# .env.example - Plantilla oficial de variables de entorno
# -----------------------------------------------------------------------------
# Este archivo es la UNICA plantilla de configuracion del proyecto.
# El instalador (install.sh) copia este archivo y reemplaza los marcadores
# __GENERATE__ por secretos criptograficos y los marcadores __DYNAMIC__
# por valores detectados automaticamente.
#
# NO edites este archivo manualmente.
# Ejecuta: sudo ./install.sh
#
# Version: 5.1.0
# =============================================================================

# -----------------------------------------------------------------------------
# Configuracion general
# -----------------------------------------------------------------------------
TZ=America/Bogota

# -----------------------------------------------------------------------------
# Matrix Synapse - Identidad del servidor
# -----------------------------------------------------------------------------
SYNAPSE_SERVER_NAME=home.arpa
SYNAPSE_PUBLIC_URL=https://matrix.home.arpa
SYNAPSE_REPORT_STATS=false
SYNAPSE_LOG_CONFIG=/data/homeserver.log.config

# -----------------------------------------------------------------------------
# Matrix Synapse - Registro de usuarios
# -----------------------------------------------------------------------------
SYNAPSE_ENABLE_REGISTRATION=false
SYNAPSE_REGISTRATION_SHARED_SECRET=__GENERATE__
SYNAPSE_MACAROON_SECRET_KEY=__GENERATE__
SYNAPSE_ADMIN_API_TOKEN=__GENERATE__
SYNAPSE_FORM_SECRET=__GENERATE__
SYNAPSE_PASSWORD_PEPPER=__GENERATE__

# -----------------------------------------------------------------------------
# PostgreSQL - Base de datos
# -----------------------------------------------------------------------------
POSTGRES_USER=synapse_user
POSTGRES_PASSWORD=__GENERATE__
POSTGRES_DB=synapse
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Redis - Cache y pubsub
# -----------------------------------------------------------------------------
REDIS_PASSWORD=__GENERATE__

# -----------------------------------------------------------------------------
# SMTP - Correo electronico para notificaciones
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.home.arpa
SMTP_PORT=587
SMTP_USER=noresponder@home.arpa
SMTP_PASS=
SMTP_FROM=noresponder@home.arpa
SMTP_FROM_NAME="Matrix Notificaciones"
SMTP_TLS=true
SMTP_REQUIRE_TLS=true
SMTP_THROTTLE_PERHOUR=50

# -----------------------------------------------------------------------------
# Element Web
# -----------------------------------------------------------------------------
ELEMENT_URL=https://element.home.arpa

# -----------------------------------------------------------------------------
# Nginx - Reverse Proxy
# -----------------------------------------------------------------------------
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
NGINX_MATRIX_DOMAIN=matrix.home.arpa
NGINX_ELEMENT_DOMAIN=element.home.arpa

# -----------------------------------------------------------------------------
# Backups
# -----------------------------------------------------------------------------
BACKUP_RETENTION_DAYS=7
BACKUP_DIR=./backups

# -----------------------------------------------------------------------------
# Red LAN (detectados automaticamente por install.sh)
# -----------------------------------------------------------------------------
LAN_CIDR=__DYNAMIC__
HOST_IP=__DYNAMIC__

# -----------------------------------------------------------------------------
# Metadatos del instalador (no modificar)
# -----------------------------------------------------------------------------
INSTALL_DATE=__DYNAMIC__
INSTALL_VERSION="5.1.0"