# =============================================================================
# log.config - Configuración de logging de Matrix Synapse
# -----------------------------------------------------------------------------
# Define los loggers, handlers y formatters para Synapse.
# Archivo referenciado desde homeserver.yaml como log_config.
# =============================================================================

version: 1

formatters:
  precise:
    format: '%(asctime)s - %(name)s - %(lineno)d - %(levelname)s - %(request)s - %(message)s'

handlers:
  console:
    class: logging.StreamHandler
    formatter: precise
    level: INFO

  buffer:
    class: logging.handlers.MemoryHandler
    capacity: 10
    target: console

  file:
    class: logging.handlers.RotatingFileHandler
    formatter: precise
    filename: /data/logs/homeserver.log
    maxBytes: 104857600    # 100 MB
    backupCount: 5
    encoding: utf8
    delay: false

loggers:
  synapse:
    level: INFO

  synapse.storage.SQL:
    level: WARNING

  synapse.http:
    level: INFO

  synapse.federation:
    level: INFO

  synapse.handlers:
    level: INFO

  synapse.metrics:
    level: WARNING

  twisted:
    level: INFO

  ldap3:
    level: INFO

  # Reduce ruido de librerías externas
  sqlalchemy:
    level: WARNING
  # markupsafe: INFO

root:
  level: INFO
  handlers: [console, file]

disable_existing_loggers: false
