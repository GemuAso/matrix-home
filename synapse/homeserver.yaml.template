# =============================================================================
# homeserver.yaml - Matrix Synapse Configuration (TEMPLATE)
# -----------------------------------------------------------------------------
# This is a TEMPLATE file. Secrets are injected via environment variables
# by synapse/entrypoint.sh at container startup.
# DO NOT edit this file directly for secrets - use .env instead.
# =============================================================================

# ---------------------------------------------------------------------------
# Server identity (injected from .env)
# ---------------------------------------------------------------------------
server_name: "${SYNAPSE_SERVER_NAME}"
public_baseurl: "${SYNAPSE_PUBLIC_URL}/"
report_stats: false

pid_file: /homeserver.pid
log_config: "${SYNAPSE_LOG_CONFIG}"

# ---------------------------------------------------------------------------
# Network - Synapse listens inside container (Nginx proxies)
# ---------------------------------------------------------------------------
listeners:
  - port: 8008
    tls: false
    type: http
    x_forwarded: true
    bind_addresses:
      - "::"
      - "0.0.0.0"
    resources:
      - names:
          - client
        compress: false

max_upload_size: 50M

# ---------------------------------------------------------------------------
# Federation - COMPLETELY DISABLED (private LAN server)
# ---------------------------------------------------------------------------
# No federation configuration needed. The server operates in isolation.

# ---------------------------------------------------------------------------
# Database - PostgreSQL (credentials from environment)
# ---------------------------------------------------------------------------
database:
  name: psycopg2
  txn_limit: 10000
  args:
    user: "${POSTGRES_USER}"
    password: "${POSTGRES_PASSWORD}"
    database: "${POSTGRES_DB}"
    host: "postgres"
    port: 5432
    cp_min: 5
    cp_max: 20
    keepalive: 30
    sslmode: disable

# ---------------------------------------------------------------------------
# Redis - Cache and pubsub (password from environment)
# ---------------------------------------------------------------------------
redis:
  enabled: true
  host: "redis"
  port: 6379
  password: "${REDIS_PASSWORD}"

# ---------------------------------------------------------------------------
# Caching
# ---------------------------------------------------------------------------
caches:
  global_factor: 1.0
  sync_response_cache_duration: 2m
  per_cache_factors:
    stateGroupCache: 2.0
    eventCache: 2.0

# ---------------------------------------------------------------------------
# User registration (disabled by default)
# ---------------------------------------------------------------------------
enable_registration: false
registration_requires_token: false
enable_registration_captcha: false
registrations_require_3pid: []
registration_shared_secret: "${SYNAPSE_REGISTRATION_SHARED_SECRET}"

# ---------------------------------------------------------------------------
# Email / SMTP - Notifications (credentials from environment)
# ---------------------------------------------------------------------------
email:
  smtp_host: "${SMTP_HOST}"
  smtp_port: ${SMTP_PORT}
  smtp_user: "${SMTP_USER}"
  smtp_pass: "${SMTP_PASS}"
  require_transport_security: true
  enable_tls: true
  notif_from: "${SMTP_FROM_NAME} <${SMTP_FROM}>"
  app_name: "Matrix"
  enable_notifs: true
  invite_client_location: "${ELEMENT_URL}/"
  subjects:
    message_from_person: "[%(app)s] %(person)s te ha enviado un mensaje"
    message_from_person_in_room: "[%(app)s] %(person)s en %(room)s te ha enviado un mensaje"
    messages_from_person: "[%(app)s] %(person)s te ha enviado mensajes"
    messages_from_person_in_room: "[%(app)s] %(person)s en %(room)s te ha enviado mensajes"
    password_reset: "[%(app)s] Restablecimiento de contrasena"
    email_validation: "[%(app)s] Verifica tu correo electronico"

# Throttling de email (anti-abuso)
rc_invites:
  per_room:
    per_second: 0.3
    burst_count: 10
  per_user:
    per_second: 0.005
    burst_count: 5
  per_issuer:
    per_second: 0.3
    burst_count: 10

# ---------------------------------------------------------------------------
# Server secrets (ALL from environment - NEVER hardcode)
# ---------------------------------------------------------------------------
macaroon_secret_key: "${SYNAPSE_MACAROON_SECRET_KEY}"
form_secret: "${SYNAPSE_FORM_SECRET}"
signing_key_path: "/data/homeserver.signing.key"
old_signing_keys: {}
keyid_signing_keys: {}

# ---------------------------------------------------------------------------
# Media Repository
# ---------------------------------------------------------------------------
media_store_path: "/data/media"
uploads_path: "/data/uploads"
max_media_upload_size: 50M
max_image_pixels: 32M

media_storage_providers:
  - module: file_system
    store_local: true
    store_remote: true
    store_synchronous: true
    config:
      directory: "/data/media"

url_preview_enabled: false

# ---------------------------------------------------------------------------
# Ratelimiting - Anti-abuse protection
# ---------------------------------------------------------------------------
rc_messages:
  per_second: 0.2
  burst_count: 10

rc_message:
  per_second: 0.2
  burst_count: 10

rc_login:
  address:
    per_second: 0.17
    burst_count: 5
  account:
    per_second: 0.17
    burst_count: 5
  failed_attempts:
    per_second: 0.17
    burst_count: 5

# ---------------------------------------------------------------------------
# TLS (terminated in Nginx - Synapse listens plain HTTP)
# ---------------------------------------------------------------------------
tls_client_connection_max_size: 102400

# ---------------------------------------------------------------------------
# User directory
# ---------------------------------------------------------------------------
user_directory:
  enabled: true
  search_all_users: false
  prefer_local_users: true

# ---------------------------------------------------------------------------
# Identity server
# ---------------------------------------------------------------------------
default_identity_server: "${SYNAPSE_PUBLIC_URL}/"
allow_public_rooms_without_auth: false

# ---------------------------------------------------------------------------
# Metrics / Monitoring (disabled for LAN)
# ---------------------------------------------------------------------------
enable_metrics: false
metrics_port: 9090

sentry:
  enabled: false

opentracing:
  enabled: false

# ---------------------------------------------------------------------------
# SSO / LDAP / OIDC / SAML / CAS (all disabled)
# ---------------------------------------------------------------------------
saml2:
  enabled: false

cas:
  enabled: false

sso:
  client_whitelist:
    - "${ELEMENT_URL}/"

# ---------------------------------------------------------------------------
# Password policy (pepper from environment)
# ---------------------------------------------------------------------------
password_config:
  enabled: true
  localdb_enabled: true
  pepper: "${SYNAPSE_PASSWORD_PEPPER}"
  policy:
    enabled: true
    minimum_length: 10
    require_digit: true
    require_symbol: true
    require_lowercase: true
    require_uppercase: true

password_providers: []

# ---------------------------------------------------------------------------
# Session management
# ---------------------------------------------------------------------------
login_via_existing_session:
  enabled: false

refreshable_access_tokens:
  enabled: true
  refresh_token_lifetime: 60d
  access_token_lifetime: 15m

# ---------------------------------------------------------------------------
# Encryption
# ---------------------------------------------------------------------------
key_backup: true
enable_cross_signing: true

# ---------------------------------------------------------------------------
# App services / Workers (disabled)
# ---------------------------------------------------------------------------
app_service_config_files: []

# ---------------------------------------------------------------------------
# Server notices
# ---------------------------------------------------------------------------
server_notices:
  system_mxid_localpart: "server"
  system_mxid_display_name: "Avisos del servidor"
  system_mxid_avatar_url: ""
  room_name: "Avisos del servidor"
  room_topic: "Anuncios del administrador del servidor"
  auto_join: true

# ---------------------------------------------------------------------------
# Spaces and features
# ---------------------------------------------------------------------------
enable_space_directory: true
enable_media_repo: true

spam_checker: []
third_party_event_rules: []
events_shard_config: {}
