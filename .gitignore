# =============================================================================
# .gitignore - Matrix Docker Project
# =============================================================================

# -----------------------------------------------------------------------------
# Secretos y variables de entorno
# -----------------------------------------------------------------------------
.env
.env.local
.env.production
.env.*.local
*.secret

# -----------------------------------------------------------------------------
# Certificados y claves
# -----------------------------------------------------------------------------
nginx/certs/*.crt
nginx/certs/*.key
nginx/certs/*.pem
nginx/certs/*.csr
nginx/certs/ca/
synapse/signing.key
synapse/*.signing.key
!synapse/signing.key.example

# -----------------------------------------------------------------------------
# Backups
# -----------------------------------------------------------------------------
backups/*.sql
backups/*.sql.gz
backups/*.tar
backups/*.tar.gz
backups/*.tgz
backups/*.zip
backups/*/
!backups/.gitkeep
!backups/README.md

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
nginx/logs/
nginx/logs/*.log
synapse/logs/

# -----------------------------------------------------------------------------
# Volúmenes locales (si se usan bind mounts en vez de volúmenes Docker)
# -----------------------------------------------------------------------------
data/
volumes/

# -----------------------------------------------------------------------------
# Sistema operativo
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~
.directory

# -----------------------------------------------------------------------------
# IDE / Editores
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
.docker/
docker-compose.override.yml

# -----------------------------------------------------------------------------
# Temporales
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.bak
*.orig
tmp/
temp/
